<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >
    <xacro:include filename="$(find robot_description)/urdf/easy_robot/common_intertia.xacro"/>
    <xacro:macro name="wheel_xacro" params="wheel_name xyz">
    <!-- 机器人的副部件 -->
    <link name="${wheel_name}_link">
        <!--部件的形状  -->
        <visual>
            <!--沿着自己的几何中心的偏移量和旋转量  -->
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <!-- 几何形状 -->
            <geometry>
                <!-- 圆柱体-->
                    <cylinder radius="0.032" length="0.04"/>
            </geometry>
            <!-- 材质-->
            <material name="black">
               <!-- 颜色 -->
               <color rgba="1.0 1.0 1.0 0.8"/>
            </material>
        </visual>
        <collision>
            <!--沿着自己的几何中心的偏移量和旋转量  -->
            <origin xyz="0.0 0.0 0.0" rpy="1.57079 0.0 0.0"/>
            <!-- 几何形状 -->
            <geometry>
                <!-- 圆柱体-->
                    <cylinder radius="0.032" length="0.04"/>
            </geometry>
            <!-- 材质-->
            <material name="black">
               <!-- 颜色 -->
               <color rgba="1.0 1.0 1.0 0.8"/>
            </material>
        </collision>
        <xacro:cylinder_inertia m="0.05" r="0.032" h="0.04"/>
    </link>

    <!-- 机器人的关节，用于组合部件-->
    <joint name="${wheel_name}_joint" type="continuous">
          <parent link="base_link"/>
          <child link="${wheel_name}_link"/>
          <!-- 固定的位置 -->
          <origin xyz="${xyz}" rpy="0.0 0.0 0.0"/>
          <!-- 旋转轴 -->
          <axis xyz="0 1 0"/>
    </joint>

    <gazebo reference="${wheel_name}_link">
           <mu1 value="20.0"/>
           <mu2 value="20.0"/>
           <!-- 刚度系数 -->
           <kp value="1000000000.0"/>  
           <!-- 阻尼系数 -->
           <kd value="1.0"/>
    </gazebo>

    </xacro:macro>
</robot>